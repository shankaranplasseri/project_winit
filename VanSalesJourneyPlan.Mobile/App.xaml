<?xml version="1.0" encoding="utf-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VanSalesJourneyPlan.Mobile.App">
    
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="PrimaryColor">#512BD4</Color>
            <Color x:Key="SecondaryColor">#DFD8F7</Color>
            <Color x:Key="TextColor">#1F1F1F</Color>
            <Color x:Key="LightTextColor">#808080</Color>
            <Color x:Key="WhiteColor">White</Color>
            
            <!-- Font Sizes -->
            <x:Double x:Key="LargeFontSize">20</x:Double>
            <x:Double x:Key="MediumFontSize">16</x:Double>
            <x:Double x:Key="SmallFontSize">14</x:Double>
            
            <!-- Styles -->
            <Style x:Key="LargeLabel" TargetType="Label">
                <Setter Property="FontSize" Value="{StaticResource LargeFontSize}" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
            
            <Style x:Key="MediumLabel" TargetType="Label">
                <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
            </Style>
            
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
    
</Application>
