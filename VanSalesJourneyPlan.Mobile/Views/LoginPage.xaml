<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VanSalesJourneyPlan.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Login"
    BackgroundColor="#F5F5F5">

    <VerticalStackLayout
        Padding="20"
        Spacing="15"
        VerticalOptions="Center">

        <Label
            FontSize="28"
            FontAttributes="Bold"
            Text="Van Sales Journey"
            TextColor="#333"
            HorizontalOptions="Center" />

        <Label
            FontSize="14"
            Text="Enter your credentials to continue"
            TextColor="#666"
            HorizontalOptions="Center" />

        <!-- Username Entry -->
        <Frame
            BorderColor="#E0E0E0"
            CornerRadius="8"
            HasShadow="False"
            Padding="12">
            <Entry
                x:Name="UsernameEntry"
                FontSize="16"
                Placeholder="Username" />
        </Frame>

        <!-- Password Entry -->
        <Frame
            BorderColor="#E0E0E0"
            CornerRadius="8"
            HasShadow="False"
            Padding="12">
            <Entry
                x:Name="PasswordEntry"
                FontSize="16"
                IsPassword="True"
                Placeholder="Password" />
        </Frame>

        <!-- Error Message -->
        <Label
            x:Name="ErrorLabel"
            FontSize="12"
            TextColor="Red"
            IsVisible="False" />

        <!-- Login Button -->
        <Button
            x:Name="LoginButton"
            BackgroundColor="#2196F3"
            Clicked="OnLoginClicked"
            CornerRadius="8"
            FontSize="16"
            FontAttributes="Bold"
            Padding="16"
            Text="Login"
            TextColor="White" />

        <!-- Loading Indicator -->
        <ActivityIndicator
            x:Name="LoadingIndicator"
            IsRunning="False"
            IsVisible="False"
            Color="#2196F3" />

        <!-- Demo Credentials Label -->
        <Label
            FontSize="11"
            Text="Demo: vansales_test01 / vansales123"
            TextColor="#999"
            HorizontalOptions="Center"
            Margin="0,20,0,0" />

    </VerticalStackLayout>

</ContentPage>

