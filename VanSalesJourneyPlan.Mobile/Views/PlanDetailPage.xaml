<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VanSalesJourneyPlan.Mobile.Views.PlanDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Plan Details"
    BackgroundColor="#F5F5F5">

    <VerticalStackLayout Spacing="0">

        <!-- Plan Header -->
        <VerticalStackLayout
            BackgroundColor="#2196F3"
            Padding="16"
            Spacing="4">
            <Label
                x:Name="PlanTitleLabel"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="White" />
            <Label
                x:Name="PlanDateLabel"
                FontSize="12"
                TextColor="White"
                Opacity="0.9" />
        </VerticalStackLayout>

        <!-- Customers List -->
        <CollectionView
            x:Name="CustomersCollectionView"
            SelectionMode="Single"
            SelectionChangedCommand="{Binding SelectCustomerCommand}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout
                    ItemSpacing="8"
                    Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        BackgroundColor="White"
                        BorderColor="#E0E0E0"
                        CornerRadius="8"
                        HasShadow="False"
                        Margin="12,0,12,0"
                        Padding="12">
                        <Grid ColumnDefinitions="1*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    Text="{Binding CustomerName}"
                                    TextColor="#333" />
                                <Label
                                    FontSize="11"
                                    Text="{Binding CustomerCode}"
                                    TextColor="#666" />
                                <Label
                                    FontSize="11"
                                    Text="{Binding PlannedVisitTime, StringFormat='Time: {0}'}"
                                    TextColor="#999" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="1"
                                BackgroundColor="#4CAF50"
                                Clicked="OnLogVisitClicked"
                                CornerRadius="6"
                                FontSize="11"
                                Padding="12,6"
                                Text="Log Visit"
                                TextColor="White"
                                VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Indicator -->
        <ActivityIndicator
            x:Name="LoadingIndicator"
            IsRunning="False"
            IsVisible="False"
            Color="#2196F3"
            VerticalOptions="Center" />

    </VerticalStackLayout>

</ContentPage>
