@model Dashboard

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Admin Dashboard</h1>
                <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger">Logout</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Customers</h5>
                    <p class="card-text" style="font-size: 2em; font-weight: bold;">@Model.TotalCustomers</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Journey Plans</h5>
                    <p class="card-text" style="font-size: 2em; font-weight: bold;">@Model.TotalPlans</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Routes</h5>
                    <p class="card-text" style="font-size: 2em; font-weight: bold;">@Model.CustomersOnRoute</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <h3>Management</h3>
            <div class="list-group">
                <a href="@Url.Action("Index", "Customers")" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">Customers</h5>
                        <span class="badge bg-primary">Manage</span>
                    </div>
                    <p class="mb-1">Add, edit, or delete customers</p>
                </a>
                <a href="@Url.Action("Index", "JourneyPlans")" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">Journey Plans</h5>
                        <span class="badge bg-success">Manage</span>
                    </div>
                    <p class="mb-1">Create and manage journey plans for field teams</p>
                </a>
            </div>
        </div>
    </div>
</div>
