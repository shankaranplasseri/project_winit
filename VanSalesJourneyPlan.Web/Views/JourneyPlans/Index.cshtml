@model List<JourneyPlanDto>

@{
    ViewData["Title"] = "Journey Plans";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Journey Plans</h1>
                <a href="@Url.Action("Create", "JourneyPlans")" class="btn btn-primary">+ Create Plan</a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Plan ID</th>
                        <th>Plan Name</th>
                        <th>Assigned User</th>
                        <th>Schedule Date</th>
                        <th>Items</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in Model)
                    {
                        <tr>
                            <td><strong>#@plan.JourneyPlanId</strong></td>
                            <td>@plan.PlanName</td>
                            <td>@plan.AssignedUserId</td>
                            <td>@plan.ScheduleDate?.ToString("MM/dd/yyyy")</td>
                            <td><span class="badge bg-info">@(plan.Items?.Count ?? 0) items</span></td>
                            <td>
                                @{
                                    var allCompleted = plan.Items?.All(i => i.IsCompleted) ?? false;
                                    var isCompleted = allCompleted && (plan.Items?.Count ?? 0) > 0;
                                }
                                @if (isCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">In Progress</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "JourneyPlans", new { id = plan.JourneyPlanId })" 
                                   class="btn btn-sm btn-info">View</a>
                                <a href="@Url.Action("Edit", "JourneyPlans", new { id = plan.JourneyPlanId })" 
                                   class="btn btn-sm btn-warning">Edit</a>
                                <form method="post" action="@Url.Action("Delete", "JourneyPlans", new { id = plan.JourneyPlanId })" 
                                      style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No journey plans found. <a href="@Url.Action("Create", "JourneyPlans")">Create one</a>
        </div>
    }

    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary mt-3">Back to Dashboard</a>
</div>
